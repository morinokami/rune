{
  "name": "@rune-cli/rune",
  "version": "0.0.13",
  "description": "Rune is a CLI framework built around the concept of file-based command routing.",
  "homepage": "https://github.com/morinokami/rune#readme",
  "bugs": {
    "url": "https://github.com/morinokami/rune/issues"
  },
  "license": "MIT",
  "author": "Shinya Fujino <shf0811@gmail.com> (https://github.com/morinokami)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/morinokami/rune.git",
    "directory": "packages/rune"
  },
  "bin": {
    "rune": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./cli": {
      "types": "./dist/cli.d.mts",
      "import": "./dist/cli.mjs"
    },
    "./test": {
      "types": "./dist/test.d.mts",
      "import": "./dist/test.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "dependencies": {
    "esbuild": "catalog:"
  },
  "devDependencies": {
    "@rune-cli/core": "workspace:*",
    "@rune-cli/test-utils": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=24.12.0"
  }
}
