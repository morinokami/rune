    },
    "./test": {
      "types": "./dist/test.d.mts",
      "import": "./dist/test.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "dependencies": {
    "oxc-parser": "catalog:",
    "rolldown": "catalog:",
    "std-env": "catalog:"
  },
  "devDependencies": {
    "@standard-schema/spec": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
