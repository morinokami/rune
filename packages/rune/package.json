{
  "name": "@rune-cli/rune",
  "version": "0.1.0",
  "description": "Rune is an agent-native CLI framework designed for the agentic era.",
  "homepage": "https://github.com/morinokami/rune#readme",
  "bugs": {
    "url": "https://github.com/morinokami/rune/issues"
  },
  "license": "MIT",
