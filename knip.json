{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-lintignore"],
  "ignoreExportsUsedInFile": true,
  "exclude": ["catalog"],
  "ignoreWorkspaces": ["examples/*", "benchmarks/fixtures/*"],
  "workspaces": {
    ".": {
      "entry": ["vite.config.ts"],
      "ignoreDependencies": ["@arethetypeswrong/cli", "@changesets/cli", "pkg-pr-new", "publint"]
    },
    "packages/rune": {
      "entry": [
        "src/index.ts",
        "src/runtime.ts",
        "src/test.ts",
        "src/cli.ts",
        "tests/**/*.test.ts",
        "vite.config.ts"
      ],
      "project": ["src/**/*.ts", "tests/**/*.ts"],
      "ignoreDependencies": ["@typescript/native-preview", "vp"]
    },
    "packages/create-rune-app": {
      "entry": ["src/commands/index.ts", "tests/**/*.test.ts", "vite.config.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"],
      "ignoreDependencies": ["@typescript/native-preview"]
    },
    "docs": {}
  }
}
